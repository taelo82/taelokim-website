# Copy to .env and fill in. .env should be gitignored.

# YouTube Data API v3 — required for Option A trend scout
# Get a key at https://console.cloud.google.com/apis/credentials
# Enable "YouTube Data API v3" for the project before creating the key.
YOUTUBE_API_KEY=

# Anthropic — required when agents move from .md prompts to API calls
ANTHROPIC_API_KEY=

# Optional: OpenRouter (cheaper token alternative for the migration target)
OPENROUTER_API_KEY=
