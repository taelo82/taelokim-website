# Track only the two project folders. Everything else in this dir is local scratch.
/*
!/.gitignore
!/taelokim-site/
!/taelo-content-system/

# Common excludes inside tracked folders
.DS_Store
*.log
node_modules/
.env
.env.local

# Claude Code local state — machine-specific paths, recreate per machine
**/.claude/settings.local.json
# Local launch configs / scratch servers — per-machine, not synced
**/.claude/launch.json
**/.claude/serve.py
